apiVersion: v1
kind: ConfigMap
metadata:
  name: laravel-config
data:
  APP_ENV: production
  APP_DEBUG: "false"
  APP_URL: https://{{HOST}}
  DB_CONNECTION: {{DB_CONNECTION}}
  DB_HOST: {{DB_HOST}}
  DB_DATABASE: laravel
  DB_USERNAME: {{DB_USERNAME}}
  REDIS_HOST: {{REDIS_HOST}}
  REDIS_PORT: "6379"
  SERVER_CONTACT: {{EMAIL}}
  # Add other environment variables here
