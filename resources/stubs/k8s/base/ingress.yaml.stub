apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: laravel-web
  annotations:
    cert-manager.io/cluster-issuer: letsencrypt-prod
spec:
  rules:
    - host: {{HOST}}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: laravel-web
                port:
                  number: 80
  tls:
    - hosts:
        - {{HOST}}
      secretName: {{HOST}}-tls
