apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: laravel-typesense
spec:
  rules:
    - host: typesense.{{HOST}}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: laravel-typesense
                port:
                  number: 8108
  tls:
    - hosts:
        - typesense.{{HOST}}
