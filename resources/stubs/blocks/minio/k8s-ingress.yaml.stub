apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: minio-console
spec:
  rules:
    - host: s3-console.{{HOST}}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: minio
                port:
                  number: 9001
  tls:
    - hosts:
        - s3-console.{{HOST}}
