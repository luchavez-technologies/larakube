apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: garage-s3
spec:
  rules:
    - host: s3.{{HOST}}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: garage
                port:
                  number: 3900
  tls:
    - hosts:
        - s3.{{HOST}}
