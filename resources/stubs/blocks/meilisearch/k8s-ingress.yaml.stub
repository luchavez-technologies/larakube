apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: laravel-meilisearch
spec:
  rules:
    - host: meilisearch.{{HOST}}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: laravel-meilisearch
                port:
                  number: 7700
  tls:
    - hosts:
        - meilisearch.{{HOST}}
